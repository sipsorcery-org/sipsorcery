<Project Sdk="Microsoft.NET.Sdk">

  <!-- Shared building blocks for the two SIPSorcery command line tools (SIPSorcery.Cli and
       SIPSorcery.Diagnostics): the CommandBase verb conventions, ExitCodes, the Cloudflare TURN
       helper and the audio/video sinks. Internal plumbing - not published as its own package; its
       DLL is bundled into each tool package. -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="8.0.1" />
    <PackageReference Include="System.CommandLine" Version="2.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SIPSorcery\SIPSorcery.csproj" />
    <!-- VideoSink uses the IVideoEncoder / VideoFormat abstractions directly. -->
    <ProjectReference Include="..\SIPSorceryMedia.Abstractions\SIPSorceryMedia.Abstractions.csproj" />
  </ItemGroup>

</Project>
