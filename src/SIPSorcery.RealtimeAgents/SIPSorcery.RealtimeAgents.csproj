<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
    <TreatWarningsAsErrors>True</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);CS1591;</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging" Version="10.0.7" />
  </ItemGroup>

  <PropertyGroup>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Authors>Aaron Clauson</Authors>
    <Copyright>Copyright © 2026 Aaron Clauson</Copyright>
    <PackageLicenseExpression>BSD-3-Clause</PackageLicenseExpression>
    <Title>SIPSorcery</Title>
    <Summary>TODO</Summary>
    <Description>TODO
    </Description>
    <Company>SIP Sorcery PTY LTD</Company>
    <Product>SIPSorcery.RealtimeAgents</Product>
    <RepositoryUrl>https://github.com/sipsorcery-org/sipsorcery</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <RepositoryBranch>master</RepositoryBranch>
    <PackageTags>WebRTC SIPSorcery Real-time Agent Voice</PackageTags>
    <NeutralLanguage>en</NeutralLanguage>
    <Version>0.1.0-beta</Version>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SIPSorcery\SIPSorcery.csproj" />
    <ProjectReference Include="..\SIPSorceryMedia.Abstractions\SIPSorceryMedia.Abstractions.csproj" />
  </ItemGroup>

</Project>
