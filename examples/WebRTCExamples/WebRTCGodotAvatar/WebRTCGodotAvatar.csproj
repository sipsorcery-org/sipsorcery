<Project Sdk="Godot.NET.Sdk/4.7.0">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Nullable>enable</Nullable>
    <!-- Override any repo-wide LangVersion: the Godot source generators emit C# 9+ syntax. -->
    <LangVersion>latest</LangVersion>
    <!-- The gd_cubism addon's C# helper scripts (addons/gd_cubism/cs) use unsafe blocks. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <!-- The gd_cubism addon bundles example scripts that target an older API version and don't
         compile; the Live2D model uses the native GDCubismUserModel via ClassDB, not these. -->
    <Compile Remove="addons/gd_cubism/example/**/*.cs" />
    <!-- build-gd-cubism.ps1 clones the gd_cubism source into ThirdParty/ to build the native
         library. That tree bundles its own copy of the addon's C# scripts, which would collide
         with addons/gd_cubism/cs (CS0102/CS0111). It is build scratch, not project source. -->
    <Compile Remove="ThirdParty/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- Pure-C# WebRTC + VP8 (no native FFmpeg). -->
    <ProjectReference Include="..\..\..\src\SIPSorcery\SIPSorcery.csproj" />
    <ProjectReference Include="..\..\..\src\SIPSorcery.VP8\SIPSorcery.VP8.csproj" />
    <!-- Optional native encoder (VIDEO_ENCODER=ffmpeg): only used when FFmpeg 8 shared
         libraries are present at runtime, e.g. the Linux container image. -->
    <ProjectReference Include="..\..\..\src\SIPSorceryMedia.FFmpeg\SIPSorceryMedia.FFmpeg.csproj" />
    <!-- The shared avatar speech/AI pipeline (TTS/STT/LLM + the IAvatarMouth seam), the same
         library the WebRTCMaxHeadroom demo uses. sherpa-onnx + LLamaSharp come transitively. -->
    <ProjectReference Include="..\AvatarPipeline\AvatarPipeline.csproj" />
  </ItemGroup>
</Project>
