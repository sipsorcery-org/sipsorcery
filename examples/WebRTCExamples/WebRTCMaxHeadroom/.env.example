# Windows Docker Desktop default. Use /opt/max-models (or similar) on Linux.
MAX_MODELS_ROOT=C:/tools

# Leave blank to auto-select Wav2Lip when its model/persona are present, otherwise cartoon.
AVATAR_RENDERER=

# Optional persona-specific Wav2Lip geometry.
NEURAL_FACE_BOX=
NEURAL_EYES=

# Optional cloud alternatives.
ELEVENLABS_API_KEY=
LLM_ENDPOINT=
LLM_MODEL=
LLM_API_KEY=
