# Unity-generated caches and per-user state
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emory[Cc]aptures/
/[Rr]ecordings/

# Auto-generated by Unity
*.csproj
*.slnx
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.opendb
*.VC.db
.vsconfig
sysinfo.txt

# SIPSorcery DLLs are staged into Assets/Plugins/ by the CI workflow
# (and by `dotnet publish` when running locally). Don't track them.
/Assets/Plugins/*.dll
/Assets/Plugins/*.pdb
/Assets/Plugins/*.xml
/Assets/Plugins/*.deps.json

# Smoke-test outputs
/test-results.xml
/unity.log
/prep.log
